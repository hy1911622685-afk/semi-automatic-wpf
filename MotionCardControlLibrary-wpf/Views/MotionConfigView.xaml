<UserControl x:Class="MotionCard.Wpf.Views.MotionConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="405">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MotionCard.Wpf;component/Themes/MotionCardHandyTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="5" Background="{StaticResource MotionSurfaceBrush}">
        <StackPanel HorizontalAlignment="Stretch">
            <Expander Header="初始化"
                      HorizontalAlignment="Stretch"
                      Style="{StaticResource MotionConfigExpanderStyle}">
                <Border Style="{StaticResource MotionConfigBodyStyle}">
                    <WrapPanel VerticalAlignment="Center">
                        <Button Command="{Binding InitFrontCommand}"
                                Content="上片位" />
                        <Button Command="{Binding InitCenterCommand}"
                                Content="下片位" />
                    </WrapPanel>
                </Border>
            </Expander>

            <Expander Header="扎针控制"
                      HorizontalAlignment="Stretch"
                      Style="{StaticResource MotionConfigExpanderStyle}">
                <Border Style="{StaticResource MotionConfigBodyStyle}">
                    <WrapPanel VerticalAlignment="Center">
                        <Button Command="{Binding ContactCommand}"
                                Content="扎针" />
                        <Button Command="{Binding SeparationCommand}"
                                Content="抬针" />
                        <Button Command="{Binding ToggleProbeModeCommand}"
                                Content="扎针状态">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MotionButtonBaseStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProbeMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource MotionAccentBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource MotionAccentBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>
                </Border>
            </Expander>

            <Expander Header="连续运动"
                      HorizontalAlignment="Stretch"
                      Style="{StaticResource MotionConfigExpanderStyle}">
                <Border Style="{StaticResource MotionConfigBodyStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Foreground="{StaticResource MotionContinuousAccentBrush}"
                                           Style="{StaticResource MotionConfigTitleStyle}"
                                           Text="连续运动" />
                                <TextBlock Style="{StaticResource MotionConfigHintStyle}"
                                           Text="按住开始连续运动，松开停止当前轴。" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{StaticResource MotionContinuousAccentBrush}"
                                           FontWeight="SemiBold"
                                           Text="速度" />
                                <ComboBox MinWidth="128"
                                          MinHeight="34"
                                          VerticalAlignment="Center"
                                          ItemsSource="{Binding SpeedModes}"
                                          SelectedItem="{Binding ContinuousSpeed}"
                                          Style="{StaticResource MotionHeaderComboBoxStyle}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Width="170"
                                  Height="170"
                                  HorizontalAlignment="Center">
                                <Button HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Style="{StaticResource MotionContinuousMoveButtonStyle}"
                                        Tag="Front"
                                        PreviewMouseLeftButtonDown="ContinuousMoveButton_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="ContinuousMoveButton_PreviewMouseLeftButtonUp"
                                        LostMouseCapture="ContinuousMoveButton_LostMouseCapture">
                                    <Path Style="{StaticResource MotionArrowIconStyle}" />
                                </Button>
                                <Button HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource MotionContinuousMoveButtonStyle}"
                                        Tag="Left"
                                        PreviewMouseLeftButtonDown="ContinuousMoveButton_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="ContinuousMoveButton_PreviewMouseLeftButtonUp"
                                        LostMouseCapture="ContinuousMoveButton_LostMouseCapture">
                                    <Path RenderTransformOrigin="0.5,0.5"
                                          Style="{StaticResource MotionArrowIconStyle}">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="-90" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Button>
                                <Border Width="58"
                                        Height="58"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="#E7F7F5"
                                        CornerRadius="29">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MotionContinuousAccentBrush}"
                                               FontWeight="SemiBold"
                                               Text="XY" />
                                </Border>
                                <Button HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource MotionContinuousMoveButtonStyle}"
                                        Tag="Right"
                                        PreviewMouseLeftButtonDown="ContinuousMoveButton_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="ContinuousMoveButton_PreviewMouseLeftButtonUp"
                                        LostMouseCapture="ContinuousMoveButton_LostMouseCapture">
                                    <Path RenderTransformOrigin="0.5,0.5"
                                          Style="{StaticResource MotionArrowIconStyle}">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="90" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Button>
                                <Button HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Style="{StaticResource MotionContinuousMoveButtonStyle}"
                                        Tag="Back"
                                        PreviewMouseLeftButtonDown="ContinuousMoveButton_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="ContinuousMoveButton_PreviewMouseLeftButtonUp"
                                        LostMouseCapture="ContinuousMoveButton_LostMouseCapture">
                                    <Path RenderTransformOrigin="0.5,0.5"
                                          Style="{StaticResource MotionArrowIconStyle}">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="180" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Button>
                            </Grid>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{StaticResource MotionMutedTextBrush}"
                                           Text="Z轴升降" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MotionAxisActionButtonStyle}"
                                            Tag="Up"
                                            PreviewMouseLeftButtonDown="ContinuousMoveButton_PreviewMouseLeftButtonDown"
                                            PreviewMouseLeftButtonUp="ContinuousMoveButton_PreviewMouseLeftButtonUp"
                                            LostMouseCapture="ContinuousMoveButton_LostMouseCapture"
                                            Content="Z+" />
                                    <Button Margin="8,0,0,0"
                                            Style="{StaticResource MotionAxisActionButtonStyle}"
                                            Tag="Down"
                                            PreviewMouseLeftButtonDown="ContinuousMoveButton_PreviewMouseLeftButtonDown"
                                            PreviewMouseLeftButtonUp="ContinuousMoveButton_PreviewMouseLeftButtonUp"
                                            LostMouseCapture="ContinuousMoveButton_LostMouseCapture"
                                            Content="Z-" />
                                </StackPanel>

                                <TextBlock Margin="0,18,0,8"
                                           Foreground="{StaticResource MotionMutedTextBrush}"
                                           Text="T轴旋转" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MotionAxisActionButtonStyle}"
                                            Tag="Redo"
                                            PreviewMouseLeftButtonDown="ContinuousMoveButton_PreviewMouseLeftButtonDown"
                                            PreviewMouseLeftButtonUp="ContinuousMoveButton_PreviewMouseLeftButtonUp"
                                            LostMouseCapture="ContinuousMoveButton_LostMouseCapture"
                                            Content="T顺" />
                                    <Button Margin="8,0,0,0"
                                            Style="{StaticResource MotionAxisActionButtonStyle}"
                                            Tag="Undo"
                                            PreviewMouseLeftButtonDown="ContinuousMoveButton_PreviewMouseLeftButtonDown"
                                            PreviewMouseLeftButtonUp="ContinuousMoveButton_PreviewMouseLeftButtonUp"
                                            LostMouseCapture="ContinuousMoveButton_LostMouseCapture"
                                            Content="T逆" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Expander>

            <Expander Header="定距运动"
                      HorizontalAlignment="Stretch"
                      Style="{StaticResource MotionConfigExpanderStyle}">
                <Border Style="{StaticResource MotionConfigBodyStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Foreground="{StaticResource MotionStepAccentBrush}"
                                           Style="{StaticResource MotionConfigTitleStyle}"
                                           Text="定距运动" />
                                <TextBlock Style="{StaticResource MotionConfigHintStyle}"
                                           Text="按输入值移动指定距离或角度。" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{StaticResource MotionStepAccentBrush}"
                                           FontWeight="SemiBold"
                                           Text="速度" />
                                <ComboBox MinWidth="128"
                                          MinHeight="34"
                                          VerticalAlignment="Center"
                                          ItemsSource="{Binding SpeedModes}"
                                          SelectedItem="{Binding FixedDistanceSpeed}"
                                          Style="{StaticResource MotionHeaderComboBoxStyle}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Width="170"
                                  Height="170"
                                  HorizontalAlignment="Center">
                                <Button HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Style="{StaticResource MotionStepMoveButtonStyle}"
                                        Command="{Binding MoveBackCommand}">
                                    <Path Style="{StaticResource MotionArrowIconStyle}" />
                                </Button>
                                <Button HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource MotionStepMoveButtonStyle}"
                                        Command="{Binding MoveLeftCommand}">
                                    <Path RenderTransformOrigin="0.5,0.5"
                                          Style="{StaticResource MotionArrowIconStyle}">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="-90" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Button>
                                <Border Width="58"
                                        Height="58"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="#EAF2FF"
                                        CornerRadius="29">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MotionStepAccentBrush}"
                                               FontWeight="SemiBold"
                                               Text="XY" />
                                </Border>
                                <Button HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource MotionStepMoveButtonStyle}"
                                        Command="{Binding MoveRightCommand}">
                                    <Path RenderTransformOrigin="0.5,0.5"
                                          Style="{StaticResource MotionArrowIconStyle}">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="90" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Button>
                                <Button HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Style="{StaticResource MotionStepMoveButtonStyle}"
                                        Command="{Binding MoveFrontCommand}">
                                    <Path RenderTransformOrigin="0.5,0.5"
                                          Style="{StaticResource MotionArrowIconStyle}">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="180" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Button>
                            </Grid>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{StaticResource MotionMutedTextBrush}"
                                               Text="移动值(mm)" />
                                    <TextBox Style="{StaticResource MotionConfigInputStyle}"
                                             Text="{Binding Distance, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <TextBlock Margin="0,12,0,8"
                                           Foreground="{StaticResource MotionMutedTextBrush}"
                                           Text="Z轴升降" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MotionAxisActionButtonStyle}"
                                            Command="{Binding MoveFixedUpCommand}"
                                            Content="Z+" />
                                    <Button Margin="8,0,0,0"
                                            Style="{StaticResource MotionAxisActionButtonStyle}"
                                            Command="{Binding MoveFixedDownCommand}"
                                            Content="Z-" />
                                </StackPanel>

                                <TextBlock Margin="0,12,0,8"
                                           Foreground="{StaticResource MotionMutedTextBrush}"
                                           Text="T轴旋转" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MotionAxisActionButtonStyle}"
                                            Command="{Binding RotateFixedRedoCommand}"
                                            Content="T顺" />
                                    <Button Margin="8,0,0,0"
                                            Style="{StaticResource MotionAxisActionButtonStyle}"
                                            Command="{Binding RotateFixedUndoCommand}"
                                            Content="T逆" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Expander>
        </StackPanel>
    </Grid>
</UserControl>
