<UserControl x:Class="WaferSystem.Wpf.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:behaviors="clr-namespace:WaferSystem.Wpf.Behaviors"
             xmlns:controls="clr-namespace:WaferSystem.Wpf.Controls"
             mc:Ignorable="d"
             d:DesignWidth="1280"
             d:DesignHeight="800"
             FontFamily="Microsoft YaHei UI"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextHintingMode="Fixed"
             Background="{StaticResource PageBgBrush}">
    <Grid SnapsToDevicePixels="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="54*" />
            <ColumnDefinition Width="35*" />
        </Grid.ColumnDefinitions>

        <Image Grid.ColumnSpan="2" Source="/WaferSystem.Wpf;component/Assets/bg.jpg" Stretch="UniformToFill" />
        <Rectangle Grid.ColumnSpan="2" Fill="{StaticResource LeftOverlayHorizontalBrush}" />
        <Rectangle Grid.ColumnSpan="2" Fill="{StaticResource LeftOverlayVerticalBrush}" />
        <controls:WaveformDecoration Grid.ColumnSpan="2" Height="140" VerticalAlignment="Bottom" Opacity="0.72" />

        <Grid Grid.Column="0" ClipToBounds="True" SnapsToDevicePixels="True">
            <DockPanel Margin="46,42,24,34" LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                    <Border Width="42" Height="42" CornerRadius="10" Background="{StaticResource LogoGradientBrush}">
                        <Border.Effect>
                            <DropShadowEffect Color="{StaticResource PrimaryBlueColor}" BlurRadius="22" ShadowDepth="0" Opacity="0.36" />
                        </Border.Effect>
                        <Path Data="M8,4 L16,4 L16,12 L8,12Z M4,6 L8,6 M4,10 L8,10 M16,6 L20,6 M16,10 L20,10 M10,0 L10,4 M14,0 L14,4 M10,12 L10,16 M14,12 L14,16"
                              Width="20"
                              Height="20"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Stroke="White"
                              StrokeThickness="1.5" />
                    </Border>
                    <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextWhiteBrush}" Text="S I R A D A" />
                        <TextBlock Margin="0,-2,0,0" FontSize="10.5" Foreground="{StaticResource TextBlue300Brush}" Text="PRECISION INSTRUMENTS &amp; CONTROL" />
                    </StackPanel>
                </StackPanel>

                <DockPanel DockPanel.Dock="Bottom" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left" Style="{StaticResource FooterTextStyle}" Text="© 2026 Sirada Technology Co., Ltd. All rights reserved." />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource CertTextStyle}" Text="ISO 9001" />
                        <TextBlock Margin="8,0" FontSize="11.2" Foreground="{StaticResource SeparatorBrush}" Text="|" />
                        <TextBlock Style="{StaticResource CertTextStyle}" Text="CNAS 认证" />
                    </StackPanel>
                </DockPanel>

                <Grid Margin="0,10" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="276" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <Border Width="126" Height="28" HorizontalAlignment="Left" Margin="0,0,0,16" Background="#331D6C9C" BorderBrush="#661D6C9C" BorderThickness="1" CornerRadius="14">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextBlue200Brush}" Text="半自动探针台" />
                        </Border>
                        <TextBlock Style="{StaticResource LeftPanelSubtitleStyle}" Text="专业测量 · 智能工控" />
                        <TextBlock Margin="0,12,0,22" FontSize="36" FontWeight="Light" Foreground="{StaticResource TitleGradientBrush}" LineHeight="44">
                            <Run Text="精密测量" />
                            <LineBreak />
                            <Run Text="驱动智造未来" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource LeftPanelBodyStyle}" Text="覆盖晶圆图、运动控制、视觉检测与工艺流程管理，一体化平台赋能半导体测试生产。" />
                    </StackPanel>

                    <controls:OrbitConstellation Grid.Column="2" MaxWidth="408" MaxHeight="408" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </DockPanel>
        </Grid>

        <Grid Grid.Column="1" ClipToBounds="True" SnapsToDevicePixels="True">
            <Canvas IsHitTestVisible="False">
                <Ellipse Width="360" Height="360" Canvas.Right="-120" Canvas.Top="-120" Fill="{StaticResource AmbientGlowBlueBrush}" Opacity="0.08" />
                <Ellipse Width="300" Height="300" Canvas.Left="-110" Canvas.Bottom="-90" Fill="{StaticResource AmbientGlowCyanBrush}" Opacity="0.06" />
            </Canvas>

            <Border Width="416"
                    Padding="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#CCFFFFFF"
                    BorderBrush="#E6FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" Direction="270" Opacity="0.26" ShadowDepth="8" Color="#153047" />
                </Border.Effect>
                <Border Padding="34,32" Background="#F4FFFFFF" CornerRadius="7" SnapsToDevicePixels="True">
                    <StackPanel>
                        <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource SystemTitleBrush}" Text="欢迎回来" />
                        <TextBlock Margin="0,8,0,30" FontSize="14" Foreground="{StaticResource SystemMutedTextBrush}" Text="请登录您的账户以继续操作" />

                        <TextBlock Style="{StaticResource FormLabelStyle}" Text="用户名" />
                        <TextBox Style="{StaticResource LoginTextBoxStyle}"
                                 Tag="请输入用户名"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,20,0,8" Style="{StaticResource FormLabelStyle}" Text="密码" />
                        <Grid>
                            <PasswordBox Style="{StaticResource LoginPasswordBoxStyle}"
                                         behaviors:PasswordBoxAssistant.BoundPassword="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                         Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                            <TextBox Style="{StaticResource LoginPasswordTextBoxStyle}"
                                     Tag="请输入密码"
                                     Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVis}}" />
                            <ToggleButton Style="{StaticResource EyeToggleButtonStyle}"
                                          HorizontalAlignment="Right"
                                          Margin="0,0,4,0"
                                          IsChecked="{Binding ShowPassword}">
                                <Grid Width="18" Height="18">
                                    <Path Data="M1,12 C4,5 8,2 12,2 C16,2 20,5 23,12 C20,19 16,22 12,22 C8,22 4,19 1,12Z M12,8 A4,4 0 1,1 12,16 A4,4 0 1,1 12,8Z"
                                          Fill="Transparent"
                                          Stretch="Uniform"
                                          Stroke="{StaticResource TextWeakBrush}"
                                          StrokeThickness="1.5"
                                          Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                    <Path Data="M1,12 C4,5 8,2 12,2 C16,2 20,5 23,12 C20,19 16,22 12,22 C8,22 4,19 1,12Z M12,8 A4,4 0 1,1 12,16 A4,4 0 1,1 12,8Z M2,22 L22,2"
                                          Fill="Transparent"
                                          Stretch="Uniform"
                                          Stroke="{StaticResource TextWeakBrush}"
                                          StrokeThickness="1.5"
                                          Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVis}}" />
                                </Grid>
                            </ToggleButton>
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="记住账户"
                                      IsChecked="{Binding RememberMe}"
                                      Style="{StaticResource LoginCheckBoxStyle}" />
                            <Button Grid.Column="1"
                                    Command="{Binding ForgotPasswordCommand}"
                                    Content="忘记密码？"
                                    Style="{StaticResource LinkButtonStyle}" />
                        </Grid>

                        <Button Margin="0,26,0,0"
                                Command="{Binding LoginCommand}"
                                Style="{StaticResource LoginButtonStyle}">
                            <Grid>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                    <TextBlock FontSize="14.4" FontWeight="SemiBold" Foreground="{StaticResource TextWhiteBrush}" Text="登录" />
                                    <Path Width="12" Height="12" Margin="8,0,0,0" Data="M9,6 L15,12 L9,18" Fill="Transparent" Stretch="Uniform" Stroke="White" StrokeThickness="2" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                                    <Grid Width="18" Height="18" Margin="0,0,9,0" RenderTransformOrigin="0.5,0.5">
                                        <Grid.RenderTransform>
                                            <RotateTransform />
                                        </Grid.RenderTransform>
                                        <Grid.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         From="0"
                                                                         To="360"
                                                                         Duration="0:0:0.8" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Grid.Triggers>
                                        <Ellipse Stroke="#66FFFFFF" StrokeThickness="2.4" />
                                        <Path Data="M9,1.5 A7.5,7.5 0 0 1 16.5,9"
                                              Stroke="White"
                                              StrokeThickness="2.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent" />
                                    </Grid>
                                    <TextBlock FontSize="14.4" FontWeight="SemiBold" Foreground="{StaticResource TextWhiteBrush}" Text="登录中..." />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Margin="0,20,0,0"
                                HorizontalAlignment="Center"
                                Command="{Binding HelpCommand}"
                                Content="遇到问题？联系技术支持"
                                Style="{StaticResource HelpButtonStyle}" />

                        <Grid Margin="0,42,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource VersionTextStyle}" Text="v1.5.2 · Build 20260527" />
                            <TextBlock Grid.Column="1" Style="{StaticResource VersionTextStyle}" Text="Sirada Control Platform" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>
