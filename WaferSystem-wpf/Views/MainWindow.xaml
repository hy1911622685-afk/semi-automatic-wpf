<Window x:Class="WaferSystem.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:motionViews="clr-namespace:MotionCard.Wpf.Views;assembly=MotionCard.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:viewModels="clr-namespace:WaferSystem.Wpf.ViewModels"
        Title="晶圆测试系统"
        Width="1480"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        Background="{StaticResource SystemSurfaceBrush}"
        ResizeMode="CanResize"
        WindowStyle="None"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="60"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.DataContext>
        <viewModels:MainWindowViewModel />
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WaferMap.Wpf;component/Themes/WaferMapHandyTheme.xaml" />
                <ResourceDictionary Source="/HKVision.Wpf;component/Themes/HKVisionHandyTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="SystemTitleBarStopButtonStyle" TargetType="Button">
                <Setter Property="MinWidth" Value="112" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Margin" Value="0,0,12,0" />
                <Setter Property="Padding" Value="11,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Background" Value="#DC2626" />
                <Setter Property="BorderBrush" Value="#B91C1C" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="FontSize" Value="13.5" />
                <Setter Property="FontWeight" Value="ExtraBold" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="PART_Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8"
                                                      Direction="270"
                                                      Opacity="0.28"
                                                      ShadowDepth="1"
                                                      Color="#991B1B" />
                                </Border.Effect>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="PART_Border" Property="Background" Value="#EF4444" />
                                    <Setter TargetName="PART_Border" Property="BorderBrush" Value="#DC2626" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="PART_Border" Property="Background" Value="#991B1B" />
                                    <Setter TargetName="PART_Border" Property="BorderBrush" Value="#7F1D1D" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.55" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource SystemSurfaceBrush}"
            BorderBrush="{StaticResource SystemTopBarBorderBrush}"
            BorderThickness="1">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Margin" Value="1" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                        <Setter Property="Margin" Value="0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid Cursor="">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="34" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Background="{StaticResource SystemTopBarBackgroundBrush}"
                    BorderBrush="{StaticResource SystemTopBarBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                          Margin="14,0,8,0"
                          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    MinWidth="230"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <Border Width="26"
                                    Height="26"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource SystemTopStatusBrush}"
                                    BorderBrush="{StaticResource SystemTopStatusBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="13">
                                <Grid>
                                    <Ellipse Width="17"
                                             Height="17"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Fill="Transparent"
                                             Stroke="{StaticResource SystemAccentBrush}"
                                             StrokeThickness="1.5" />
                                    <Path Data="M13,4.5 L13,21.5 M4.5,13 L21.5,13"
                                          Stroke="{StaticResource SystemAccentBrush}"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeThickness="1"
                                          Opacity="0.55" />
                                    <Ellipse Width="3.2"
                                             Height="3.2"
                                             Margin="8,8,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top"
                                             Fill="{StaticResource SystemAccentBrush}" />
                                    <Ellipse Width="3.2"
                                             Height="3.2"
                                             Margin="0,8,8,0"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Top"
                                             Fill="{StaticResource SystemAccentBrush}" />
                                    <Ellipse Width="3.2"
                                             Height="3.2"
                                             Margin="8,0,0,8"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Bottom"
                                             Fill="{StaticResource SystemAccentBrush}" />
                                    <Ellipse Width="3.2"
                                             Height="3.2"
                                             Margin="0,0,8,8"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Bottom"
                                             Fill="{StaticResource SystemAccentBrush}" />
                                </Grid>
                            </Border>
                            <TextBlock Margin="9,0,0,0"
                                       VerticalAlignment="Center"
                                       FontFamily="Microsoft YaHei UI"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SystemTitleBrush}"
                                       Text="晶圆测试系统"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>


                        <StackPanel Orientation="Horizontal" Grid.Column="2"
                                
                                VerticalAlignment="Center">
                            <Button Command="{Binding StopAllAxesCommand}"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                    Style="{StaticResource SystemTitleBarStopButtonStyle}"
                                    ToolTip="停止所有轴运动">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="16"
                                          Height="16"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center">
                                        <Border Background="#33FFFFFF"
                                                BorderBrush="#88FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="3" />
                                        <Rectangle Width="7"
                                                   Height="7"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                   RadiusX="1"
                                                   RadiusY="1" />
                                    </Grid>
                                    <TextBlock VerticalAlignment="Center"
                                               FontWeight="ExtraBold"
                                               Text="停止" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="RuntimeLogButton"
                                    Click="RuntimeLogButton_Click"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                    Style="{StaticResource SystemTitleBarButtonStyle}"
                                    ToolTip="运行日志">
                                <Viewbox Width="20" Height="20">
                                    <Canvas Width="16" Height="16">
                                        <Path Data="M2.5,2.5 L13.5,2.5 L13.5,13.5 L2.5,13.5 Z"
                                              Fill="Transparent"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeLineJoin="Round"
                                              StrokeThickness="1.5" />
                                        <Path Data="M5,5 L11,5 M5,8 L11,8 M5,11 L9,11"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeThickness="1.4" />
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding OpenProjectCommand}"
                                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                        Style="{StaticResource SystemTitleBarButtonStyle}"
                                        ToolTip="项目">
                                <Viewbox Width="20" Height="20">
                                    <Canvas Width="16" Height="16">
                                        <Path Data="M1.5,4.5 L6,4.5 L7.4,6 L14.5,6 L14.5,13.5 L1.5,13.5 Z"
                                                  Fill="Transparent"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeLineJoin="Round"
                                                  StrokeThickness="1.7" />
                                        <Path Data="M1.5,4.5 L1.5,3 L5.8,3 L7.1,4.5"
                                                  Fill="Transparent"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeLineJoin="Round"
                                                  StrokeThickness="1.7" />
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding OpenSettingsCommand}"
                                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                        Style="{StaticResource SystemTitleBarButtonStyle}"
                                        ToolTip="设置">
                                <Viewbox Width="21" Height="21">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M19.43,12.98 C19.47,12.66 19.5,12.33 19.5,12 C19.5,11.67 19.47,11.34 19.43,11.02 L21.54,9.37 C21.73,9.22 21.78,8.95 21.66,8.73 L19.66,5.27 C19.54,5.05 19.28,4.96 19.05,5.05 L16.56,6.05 C16.04,5.65 15.48,5.32 14.86,5.07 L14.48,2.42 C14.44,2.18 14.24,2 14,2 L10,2 C9.76,2 9.56,2.18 9.52,2.42 L9.14,5.07 C8.52,5.32 7.96,5.66 7.44,6.05 L4.95,5.05 C4.72,4.96 4.46,5.05 4.34,5.27 L2.34,8.73 C2.22,8.95 2.27,9.22 2.46,9.37 L4.57,11.02 C4.53,11.34 4.5,11.67 4.5,12 C4.5,12.33 4.53,12.66 4.57,12.98 L2.46,14.63 C2.27,14.78 2.22,15.05 2.34,15.27 L4.34,18.73 C4.46,18.95 4.72,19.04 4.95,18.95 L7.44,17.95 C7.96,18.35 8.52,18.68 9.14,18.93 L9.52,21.58 C9.56,21.82 9.76,22 10,22 L14,22 C14.24,22 14.44,21.82 14.48,21.58 L14.86,18.93 C15.48,18.68 16.04,18.34 16.56,17.95 L19.05,18.95 C19.28,19.04 19.54,18.95 19.66,18.73 L21.66,15.27 C21.78,15.05 21.73,14.78 21.54,14.63 Z"
                                                  Fill="Transparent"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeLineJoin="Round"
                                                  StrokeThickness="1.8" />
                                        <Ellipse Width="6"
                                                     Height="6"
                                                     Canvas.Left="9"
                                                     Canvas.Top="9"
                                                     Fill="Transparent"
                                                     Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                     StrokeThickness="1.9" />
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Click="MinimizeButton_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource SystemTitleBarButtonStyle}"
                                ToolTip="最小化">
                            <Viewbox Width="12" Height="12">
                                <Canvas Width="12" Height="12">
                                    <Path Data="M1,6 L11,6"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeThickness="1.8" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Click="MaximizeRestoreButton_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource SystemTitleBarButtonStyle}"
                                ToolTip="最大化或还原">
                            <Grid Width="12" Height="12">
                                <Path
                                      Data="M1.5,1.5 L10.5,1.5 L10.5,10.5 L1.5,10.5 Z"
                                      Fill="Transparent"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeLineJoin="Round"
                                      StrokeThickness="1.4">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path
                                      Data="M3.5,1.5 L10.5,1.5 L10.5,8.5 M3.5,3.5 L1.5,3.5 L1.5,10.5 L8.5,10.5 L8.5,8.5"
                                      Fill="Transparent"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeLineJoin="Round"
                                      StrokeThickness="1.4">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Grid>
                        </Button>
                        <Button Command="{Binding CloseApplicationCommand}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource SystemTitleBarCloseButtonStyle}"
                                ToolTip="关闭">
                            <Viewbox Width="12" Height="12">
                                <Canvas Width="12" Height="12">
                                    <Path Data="M2,2 L10,10 M10,2 L2,10"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeThickness="1.8" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Grid.Column="0"
                  Margin="10"
                  ClipToBounds="False">
                <Border Background="{StaticResource SystemPanelBrush}">
                    <ContentControl Content="{Binding GeneralWorkbenchView}" />
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGeneralWorkbenchVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Border Background="{StaticResource SystemPanelBrush}"
                    Panel.ZIndex="{Binding WaferViewZIndex}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                            Height="30"
                            Background="{StaticResource SystemHeaderAltBrush}">
                            <Grid Margin="8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="晶圆图" />
                                <Button Grid.Column="1"
                                    Width="76"
                                    Command="{Binding SwapWorkbenchCommand}"
                                    Content="切换"
                                    FontSize="12"
                                    Visibility="{Binding WorkbenchSwitcherVisibility}" />
                            </Grid>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWaferWorkbenchMini}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <ContentControl Grid.Row="1"
                                    Content="{Binding WaferWorkbenchView}" />
                    </Grid>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <Setter Property="Width" Value="Auto" />
                            <Setter Property="Height" Value="Auto" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="BorderBrush" Value="{StaticResource SystemBorderBrush}" />
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWaferWorkbenchVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsWaferWorkbenchMini}" Value="True">
                                    <Setter Property="Width" Value="320" />
                                    <Setter Property="Height" Value="300" />
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                    <Setter Property="VerticalAlignment" Value="Top" />
                                    <Setter Property="Margin" Value="0,68,0,0" />
                                    <Setter Property="BorderThickness" Value="1" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Border Background="{StaticResource SystemPanelBrush}"
                    Panel.ZIndex="{Binding VisionViewZIndex}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                            Height="30"
                            Background="{StaticResource SystemHeaderAltBrush}">
                            <Grid Margin="8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="视场" />
                                <Button Grid.Column="1"
                               Width="76"
                               Command="{Binding SwapWorkbenchCommand}"
                               Content="切换"
                               FontSize="12"
                               Visibility="{Binding WorkbenchSwitcherVisibility}" />

                            </Grid>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVisionWorkbenchMini}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <ContentControl Grid.Row="1"
                                    Content="{Binding VisionWorkbenchView}" />
                    </Grid>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <Setter Property="Width" Value="Auto" />
                            <Setter Property="Height" Value="Auto" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="BorderBrush" Value="{StaticResource SystemBorderBrush}" />
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVisionWorkbenchVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsVisionWorkbenchMini}" Value="True">
                                    <Setter Property="Width" Value="320" />
                                    <Setter Property="Height" Value="300" />
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                    <Setter Property="VerticalAlignment" Value="Top" />
                                    <Setter Property="Margin" Value="0,68,0,0" />
                                    <Setter Property="BorderThickness" Value="1" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Border Width="320"
                        MaxHeight="260"
                        Margin="8,0,0,8"
                        Padding="10,8"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="{StaticResource SystemPanelBrush}"
                        BorderBrush="{StaticResource SystemBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        IsHitTestVisible="False"
                        Panel.ZIndex="{Binding VisionViewZIndex}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16"
                                          Direction="270"
                                          Opacity="0.16"
                                          ShadowDepth="4" />
                    </Border.Effect>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVisionWorkbenchMini}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SystemTitleBrush}"
                                       Text="测试统计" />

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Foreground="{StaticResource SystemMutedTextBrush}"
                                           Text="加入测试" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SystemTitleBrush}"
                                           Text="{Binding WaferViewModel.JoinedTestSummary}" />

                                <TextBlock Grid.Row="1"
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource SystemMutedTextBrush}"
                                           Text="已测试" />
                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           Margin="0,3,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SystemTitleBrush}"
                                           Text="{Binding WaferViewModel.TestedSummary}" />
                            </Grid>

                            <ItemsControl Grid.Row="4"
                                          ItemsSource="{Binding WaferViewModel.BinTestStatistics}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="10"
                                                    Height="10"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding ColorBrush}"
                                                    BorderBrush="{StaticResource SystemBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="2" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{StaticResource SystemTitleBrush}"
                                                       Text="{Binding DisplayName}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2"
                                                       Margin="8,0,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SystemTitleBrush}"
                                                       Text="{Binding SummaryText}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                </Border>


            </Grid>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,10,10,8"
                    Background="{StaticResource SystemPanelBrush}"
                    BorderBrush="{StaticResource SystemBorderBrush}"
                    BorderThickness="1">
                <TabControl Margin="8"
                            ItemsSource="{Binding RightTabs}" />
            </Border>

            <Border Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Background="{StaticResource SystemHeaderAltBrush}">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="White"
                               Text="{Binding StatusText}" />
                    <motionViews:CtrlPositionView Grid.Column="2"
                                                  VerticalAlignment="Center"
                                                  DataContext="{Binding MotionViewModel}" />
                </Grid>
            </Border>

            <Grid Grid.RowSpan="3"
                  Grid.ColumnSpan="2"
                  Panel.ZIndex="1000"
                  Background="#99000000"
                  IsHitTestVisible="True"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsWorkflowInteractionLocked}" Value="True" />
                                    <Condition Binding="{Binding IsStartupLoading}" Value="False" />
                                    <Condition Binding="{Binding MotionViewModel.IsInitializing}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Width="320"
                        Padding="24,20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{StaticResource SystemPanelBrush}"
                        BorderBrush="{StaticResource SystemBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22"
                                          Direction="270"
                                          Opacity="0.26"
                                          ShadowDepth="6" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SystemTitleBrush}"
                                   Text="设备已连接，测试控制中" />
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource SystemMutedTextBrush}"
                                   Text="当前仅允许通过外部设备控制测试流程" />
                        <Button Margin="0,18,0,0"
                                Height="34"
                                Command="{Binding DisconnectSocketDeviceCommand}"
                                Content="断开连接" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.RowSpan="3"
                  Grid.ColumnSpan="2"
                  Panel.ZIndex="1001"
                  Background="Transparent"
                  IsHitTestVisible="False"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStartupLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding MotionViewModel.IsInitializing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding WaferViewModel.IsGeneratingWaferMap}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Width="260"
                        Height="150"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{StaticResource SystemPanelBrush}"
                        BorderBrush="{StaticResource SystemBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20"
                                          Direction="270"
                                          Opacity="0.24"
                                          ShadowDepth="5" />
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Grid Width="42"
                              Height="42"
                              HorizontalAlignment="Center">
                            <Grid.RenderTransform>
                                <RotateTransform CenterX="21" CenterY="21" />
                            </Grid.RenderTransform>
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             From="0"
                                                             To="360"
                                                             Duration="0:0:1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Grid.Triggers>
                            <Ellipse Stroke="#E1E8EF"
                                     StrokeThickness="5" />
                            <Path Data="M21,2 A19,19 0 0 1 40,21"
                                  Stroke="{StaticResource SystemAccentBrush}"
                                  StrokeThickness="5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent" />
                        </Grid>
                        <TextBlock Margin="0,16,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SystemTitleBrush}"
                                   Text="{Binding StartupLoadingMessage}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStartupLoading}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,16,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SystemTitleBrush}"
                                   Text="{Binding MotionViewModel.InitializingMessage}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsStartupLoading}" Value="False" />
                                                <Condition Binding="{Binding MotionViewModel.IsInitializing}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,16,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SystemTitleBrush}"
                                   Text="正在生成晶圆图">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsStartupLoading}" Value="False" />
                                                <Condition Binding="{Binding MotionViewModel.IsInitializing}" Value="False" />
                                                <Condition Binding="{Binding WaferViewModel.IsGeneratingWaferMap}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,6,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource SystemMutedTextBrush}"
                                   Text="&#x8BF7;&#x7B49;&#x5F85;&#x5F53;&#x524D;&#x64CD;&#x4F5C;&#x5B8C;&#x6210;" />
                    </StackPanel>
                </Border>
            </Grid>

            <Popup x:Name="RuntimeLogPopup"
                   PlacementTarget="{Binding ElementName=RuntimeLogButton}"
                   Placement="Bottom"
                   HorizontalOffset="-244"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Width="520"
                        Height="360"
                        Padding="12"
                        Background="{StaticResource SystemPanelBrush}"
                        BorderBrush="{StaticResource SystemBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16"
                                          Direction="270"
                                          Opacity="0.18"
                                          ShadowDepth="4" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0">
                            <TextBlock DockPanel.Dock="Left"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SystemSectionTitleStyle}"
                                       Text="运行日志" />
                            <Button DockPanel.Dock="Right"
                                    MinWidth="78"
                                    Height="28"
                                    Command="{Binding ClearLogCommand}"
                                    Content="清空" />
                        </DockPanel>
                        <ListBox Grid.Row="2"
                                 BorderBrush="{StaticResource SystemBorderBrush}"
                                 ItemsSource="{Binding Logs}" />
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
