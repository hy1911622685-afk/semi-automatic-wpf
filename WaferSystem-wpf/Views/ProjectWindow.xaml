<Window x:Class="WaferSystem.Wpf.Views.ProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="项目"
        Width="520"
        Height="320"
        Background="{StaticResource SystemSurfaceBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Border Style="{StaticResource SystemCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Style="{StaticResource SystemSectionTitleStyle}"
                           Text="项目管理" />
                <TextBlock Grid.Row="1"
                           Margin="0,8,0,12"
                           Foreground="{StaticResource SystemMutedTextBrush}"
                           Text="主程序已预留项目管理页，后续可继续迁移原项目文件读写逻辑。" />
                <ListBox Grid.Row="2" BorderBrush="{StaticResource SystemBorderBrush}">
                    <ListBoxItem Content="默认项目" />
                </ListBox>
                <StackPanel Grid.Row="3"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button Content="新建" />
                    <Button Content="打开" />
                    <Button Content="关闭" Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
