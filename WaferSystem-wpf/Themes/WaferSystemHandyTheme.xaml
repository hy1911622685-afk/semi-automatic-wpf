    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource SystemSurfaceBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SystemTextBrush}" />
    </Style>

    <Color x:Key="PageBgColor">#FFEEF3F8</Color>
    <Color x:Key="PrimaryBlueColor">#FF1D6C9C</Color>
    <SolidColorBrush x:Key="PageBgBrush" Color="{StaticResource PageBgColor}" />
    <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlueColor}" />
    <SolidColorBrush x:Key="LightBlueBrush" Color="#FF2A7FB3" />
    <SolidColorBrush x:Key="PaleBlueBrush" Color="#FF77B7D4" />
    <SolidColorBrush x:Key="TextWhiteBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="TextBlue200Brush" Color="#FFDDEEF7" />
    <SolidColorBrush x:Key="TextBlue300Brush" Color="#FFB9DDE4" />
    <SolidColorBrush x:Key="TextLabelBrush" Color="#FF435468" />
    <SolidColorBrush x:Key="TextSubBrush" Color="#FF6A7685" />
    <SolidColorBrush x:Key="TextWeakBrush" Color="#FF7D93AD" />
    <SolidColorBrush x:Key="TextDimBrush" Color="#FF6B7A8D" />
    <SolidColorBrush x:Key="TextBodyBrush" Color="#FFB0C4DE" />
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#FF9AA8B8" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="#FF9DB0C1" />
    <SolidColorBrush x:Key="InputBgBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#FFC8D8E6" />
    <SolidColorBrush x:Key="InputFocusBgBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#FF1D6C9C" />
    <LinearGradientBrush x:Key="LoginButtonBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF1D6C9C" Offset="0" />
        <GradientStop Color="#FF0E7490" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LoginButtonHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF2A7FB3" Offset="0" />
        <GradientStop Color="#FF1597A8" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LoginButtonPressedBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF15577F" Offset="0" />
        <GradientStop Color="#FF0F5F73" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LogoGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF1D6C9C" Offset="0" />
        <GradientStop Color="#FF0E7490" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="TitleGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFFFF" Offset="0" />
        <GradientStop Color="#FF93C5FD" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LeftOverlayHorizontalBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#F2153047" Offset="0" />
        <GradientStop Color="#C21E5B84" Offset="0.48" />
        <GradientStop Color="#E8153047" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LeftOverlayVerticalBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#8A153047" Offset="0" />
        <GradientStop Color="#221D6C9C" Offset="0.4" />
        <GradientStop Color="#D9153047" Offset="1" />
    </LinearGradientBrush>
    <RadialGradientBrush x:Key="AmbientGlowBlueBrush">
        <GradientStop Color="#1D6C9C" Offset="0" />
        <GradientStop Color="Transparent" Offset="0.7" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="AmbientGlowCyanBrush">
        <GradientStop Color="#0E7490" Offset="0" />
        <GradientStop Color="Transparent" Offset="0.7" />
    </RadialGradientBrush>

    <Style x:Key="LoginTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="48" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
        <Setter Property="Foreground" Value="{StaticResource SystemTextBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource SystemAccentBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border" Background="{StaticResource InputBgBrush}" BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                            <TextBlock x:Name="placeholder" Text="{TemplateBinding Tag}" Foreground="{StaticResource PlaceholderBrush}" Margin="18,0,0,0" VerticalAlignment="Center" FontSize="14" IsHitTestVisible="False" Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource InputFocusBorderBrush}" />
                            <Setter TargetName="border" Property="Background" Value="{StaticResource InputFocusBgBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="LoginPasswordTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource LoginTextBoxStyle}">
        <Setter Property="Padding" Value="16,0,48,0" />
    </Style>
    <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Height" Value="48" />
        <Setter Property="Padding" Value="16,0,48,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
        <Setter Property="Foreground" Value="{StaticResource SystemTextBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource SystemAccentBrush}" />
        <Setter Property="Tag" Value="请输入密码" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="border" Background="{StaticResource InputBgBrush}" BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                            <TextBlock x:Name="placeholder" Text="{TemplateBinding Tag}" Foreground="{StaticResource PlaceholderBrush}" Margin="18,0,0,0" VerticalAlignment="Center" FontSize="14" IsHitTestVisible="False" Visibility="Visible" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource InputFocusBorderBrush}" />
                            <Setter TargetName="border" Property="Background" Value="{StaticResource InputFocusBgBrush}" />
                        </Trigger>
                        <Trigger Property="behaviors:PasswordBoxAssistant.HasPassword" Value="True">
                            <Setter TargetName="placeholder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="LoginCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextSubBrush}" />
        <Setter Property="FontSize" Value="12.8" />
    </Style>
    <Style x:Key="LinkButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource LightBlueBrush}" />
        <Setter Property="FontSize" Value="12.8" />
    </Style>
    <Style x:Key="LoginButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="48" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource LoginButtonBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource LoginButtonHoverBrush}" />
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#1D6C9C" BlurRadius="22" ShadowDepth="0" Opacity="0.28" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource LoginButtonPressedBrush}" />
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.985" ScaleY="0.985" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#0E7490" BlurRadius="12" ShadowDepth="0" Opacity="0.22" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter TargetName="border" Property="Opacity" Value="0.86" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="EyeToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
    </Style>
    <Style x:Key="HelpButtonStyle" TargetType="Button" BasedOn="{StaticResource LinkButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource TextWeakBrush}" />
        <Setter Property="FontSize" Value="12.5" />
    </Style>
    <Style x:Key="LeftPanelSubtitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBlue200Brush}" />
        <Setter Property="FontSize" Value="12.5" />
    </Style>
    <Style x:Key="LeftPanelBodyStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBodyBrush}" />
        <Setter Property="FontSize" Value="14.1" />
        <Setter Property="LineHeight" Value="26" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="FormLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextLabelBrush}" />
        <Setter Property="FontSize" Value="12.8" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <Style x:Key="FooterTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextWeakBrush}" />
        <Setter Property="FontSize" Value="11.5" />
    </Style>
    <Style x:Key="VersionTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
        <Setter Property="FontSize" Value="11.2" />
    </Style>
    <Style x:Key="CertTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextWeakBrush}" />
        <Setter Property="FontSize" Value="11.2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Key="LoginWindowButtonStyle" TargetType="Button" BasedOn="{StaticResource SystemTitleBarButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource SystemTitleBrush}" />
    </Style>
    <Style x:Key="LoginWindowCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource SystemTitleBarCloseButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource SystemDangerBrush}" />
    </Style>
</ResourceDictionary>
