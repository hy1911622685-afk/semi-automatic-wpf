    <Style x:Key="SystemTitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource SystemTitleBarButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource SystemDangerBrush}" />
        <Setter Property="Template">
