                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PART_Border" Property="Background" Value="{StaticResource SystemTopActionButtonPressedBrush}" />
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{StaticResource SystemTopBarAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
