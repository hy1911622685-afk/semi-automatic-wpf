<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <RootNamespace>HKVision.Wpf</RootNamespace>
    <AssemblyName>HKVision.Wpf</AssemblyName>
    <Deterministic>true</Deterministic>
    <PlatformTarget>x64</PlatformTarget>
    <VisionMasterAssemblyPath>D:\Program Files\VisionMaster4.3.0\Development\V4.x\ComControls\Assembly</VisionMasterAssemblyPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="HandyControl" Version="3.5.1" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MyAsset-wpf\MyAsset-wpf.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="IMVSFastFeatureMatchModuCs">
      <HintPath>$(VisionMasterAssemblyPath)\IMVSFastFeatureMatchModuCs.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="MvCameraControl.Net">
      <HintPath>myLibs\MvCameraControl.Net.dll</HintPath>
    </Reference>
    <Reference Include="VM.Core">
      <HintPath>$(VisionMasterAssemblyPath)\VM.Core.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="VM.PlatformSDKCS">
      <HintPath>$(VisionMasterAssemblyPath)\VM.PlatformSDKCS.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="VM.Xml">
      <HintPath>$(VisionMasterAssemblyPath)\VM.Xml.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="VMControls.BaseInterface">
      <HintPath>$(VisionMasterAssemblyPath)\VMControls.BaseInterface.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="VMControls.Interface">
      <HintPath>$(VisionMasterAssemblyPath)\VMControls.Interface.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="VMControls.RenderInterface">
      <HintPath>$(VisionMasterAssemblyPath)\VMControls.RenderInterface.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="VMControls.WPF">
      <HintPath>$(VisionMasterAssemblyPath)\VMControls.WPF.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="VMControls.WPF.Release">
      <HintPath>$(VisionMasterAssemblyPath)\VMControls.WPF.Release.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="WPFBase">
      <HintPath>$(VisionMasterAssemblyPath)\WPFBase.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

</Project>
