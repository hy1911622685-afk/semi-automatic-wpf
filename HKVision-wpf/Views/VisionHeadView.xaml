<UserControl x:Class="HKVision.Wpf.Views.VisionHeadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Height="60"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HKVision.Wpf;component/Themes/HKVisionHandyTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SingleRunButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource VisionToolbarTextButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSingleRunActive}" Value="True">
                        <Setter Property="Background" Value="{StaticResource VisionAccentBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource VisionAccentBrush}" />
                        <Setter Property="Foreground" Value="White" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ContinuousRunButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource VisionToolbarTextButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsContinuousRunActive}" Value="True">
                        <Setter Property="Background" Value="{StaticResource VisionAccentBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource VisionAccentBrush}" />
                        <Setter Property="Foreground" Value="White" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource VisionPanelBrush}"
            BorderBrush="{StaticResource VisionBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,10">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Command="{Binding SingleRunCommand}"
                        Style="{StaticResource SingleRunButtonStyle}"
                        ToolTip="单次拍照">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE722;" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="单次拍照" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ContinueRunCommand}"
                        Style="{StaticResource ContinuousRunButtonStyle}"
                        ToolTip="连续拍照">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE8EE;" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="连续拍照" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Separator DockPanel.Dock="Left"
                       Width="1"
                       Margin="4,4,8,4"
                       Background="{StaticResource VisionBorderBrush}" />
            <StackPanel DockPanel.Dock="Left"
            VerticalAlignment="Center"
            Orientation="Horizontal">
                <Button Command="{Binding MoveNearestPointCommand}"
                        Style="{StaticResource VisionToolbarTextButtonStyle}"
                        ToolTip="最近点">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="16"
                              Height="16"
                              VerticalAlignment="Center">
                            <Ellipse Width="12"
                                     Height="12"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Fill="Transparent"
                                     Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                     StrokeThickness="1.6" />
                            <Ellipse Width="4"
                                     Height="4"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <Path Data="M8,0 L8,3 M8,13 L8,16 M0,8 L3,8 M13,8 L16,8"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeEndLineCap="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeThickness="1.4" />
                        </Grid>
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="最近点" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding ToggleFovScanCommand}"
                        Style="{StaticResource VisionToolbarTextButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="15"
                              Height="15"
                              VerticalAlignment="Center">
                            <Grid.Resources>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <Setter Property="RadiusX" Value="0.6" />
                                    <Setter Property="RadiusY" Value="0.6" />
                                </Style>
                            </Grid.Resources>

                            <Rectangle Width="5" Height="5" HorizontalAlignment="Left" VerticalAlignment="Top" />
                            <Rectangle Width="2" Height="2" Margin="1.5,1.5,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="White" />
                            <Rectangle Width="5" Height="5" HorizontalAlignment="Right" VerticalAlignment="Top" />
                            <Rectangle Width="2" Height="2" Margin="0,1.5,1.5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Fill="White" />
                            <Rectangle Width="5" Height="5" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
                            <Rectangle Width="2" Height="2" Margin="1.5,0,0,1.5" HorizontalAlignment="Left" VerticalAlignment="Bottom" Fill="White" />

                            <Rectangle Width="2" Height="2" Margin="7,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                            <Rectangle Width="2" Height="2" Margin="10,7,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                            <Rectangle Width="2" Height="2" Margin="7,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                            <Rectangle Width="2" Height="5" Margin="13,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                            <Rectangle Width="5" Height="2" Margin="8,13,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        </Grid>
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding FovScanButtonText}" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding ConfigureParamCommand}"
                        Style="{StaticResource VisionToolbarTextButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE713;" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="参数配置" />
                    </StackPanel>
                </Button>
                
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
