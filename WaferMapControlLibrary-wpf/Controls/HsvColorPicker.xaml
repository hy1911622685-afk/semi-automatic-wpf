<UserControl x:Class="WaferMap.Wpf.Controls.HsvColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="ColorArea"
                Grid.Row="0"
                Background="Red"
                BorderBrush="#DCE3EE"
                BorderThickness="1"
                ClipToBounds="True"
                CornerRadius="5"
                MouseDown="ColorArea_MouseDown"
                MouseLeave="ColorArea_MouseLeave"
                MouseMove="ColorArea_MouseMove"
                MouseUp="ColorArea_MouseUp"
                SizeChanged="PickerPart_SizeChanged">
            <Grid ClipToBounds="True">
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">
                            <GradientStop Offset="0"
                                          Color="White" />
                            <GradientStop Offset="1"
                                          Color="#00FFFFFF" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="0,1">
                            <GradientStop Offset="0"
                                          Color="#00000000" />
                            <GradientStop Offset="1"
                                          Color="Black" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Canvas IsHitTestVisible="False">
                    <Ellipse x:Name="ColorThumb"
                             Width="12"
                             Height="12"
                             Fill="Transparent"
                             Stroke="White"
                             StrokeThickness="2" />
                </Canvas>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              x:Name="HueHost"
              Height="18"
              Margin="0,8,0,0"
              MouseDown="HueTrack_MouseDown"
              MouseLeave="HueTrack_MouseLeave"
              MouseMove="HueTrack_MouseMove"
              MouseUp="HueTrack_MouseUp"
              SizeChanged="PickerPart_SizeChanged">
            <Border x:Name="HueTrack"
                    Height="14"
                    Margin="7,0"
                    VerticalAlignment="Center"
                    ClipToBounds="True"
                    CornerRadius="7">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,0">
                        <GradientStop Offset="0.000"
                                      Color="#FFFF0000" />
                        <GradientStop Offset="0.167"
                                      Color="#FFFFFF00" />
                        <GradientStop Offset="0.333"
                                      Color="#FF00FF00" />
                        <GradientStop Offset="0.500"
                                      Color="#FF00FFFF" />
                        <GradientStop Offset="0.667"
                                      Color="#FF0000FF" />
                        <GradientStop Offset="0.833"
                                      Color="#FFFF00FF" />
                        <GradientStop Offset="1.000"
                                      Color="#FFFF0000" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Canvas IsHitTestVisible="False">
                <Ellipse x:Name="HueThumb"
                         Width="14"
                         Height="14"
                         Fill="White"
                         Stroke="#8892A0"
                         StrokeThickness="1" />
            </Canvas>
        </Grid>
    </Grid>
</UserControl>
