<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:hc="https://handyorg.github.io/handycontrol">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml" />
        <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <SolidColorBrush x:Key="WaferSurfaceBrush" Color="#F3F6FA" />
    <SolidColorBrush x:Key="WaferPanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="WaferBorderBrush" Color="#DCE3EE" />
    <SolidColorBrush x:Key="WaferTextBrush" Color="#222A35" />
    <SolidColorBrush x:Key="WaferMutedTextBrush" Color="#667386" />
    <SolidColorBrush x:Key="WaferAccentBrush" Color="#1F7A8C" />
    <SolidColorBrush x:Key="WaferAccentHoverBrush" Color="#256F83" />
    <SolidColorBrush x:Key="WaferAccentPressedBrush" Color="#185A6A" />
    <SolidColorBrush x:Key="WaferWarningBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="WaferDangerBrush" Color="#C24141" />
    <SolidColorBrush x:Key="WaferButtonBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="WaferButtonHoverBrush" Color="#EAF4F7" />
    <SolidColorBrush x:Key="WaferButtonPressedBrush" Color="#D6EBF0" />
    <SolidColorBrush x:Key="WaferInputBrush" Color="#FFFFFF" />

    <Style x:Key="WaferCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource WaferPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WaferBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="10" Direction="270" Opacity="0.08" ShadowDepth="1" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WaferSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource WaferTextBrush}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="WaferFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource WaferMutedTextBrush}" />
        <Setter Property="Margin" Value="0,7,0,3" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Height" Value="30" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Background" Value="{StaticResource WaferInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WaferBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource WaferTextBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource WaferAccentBrush}" />
        <Setter Property="SelectionBrush" Value="#A9DDE7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"
                                      VerticalContentAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="#B9C7D8" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{StaticResource WaferAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter Property="Background" Value="#F6F8FA" />
                            <Setter Property="Foreground" Value="{StaticResource WaferMutedTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WaferButtonBaseStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="68" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Margin" Value="3" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{StaticResource WaferButtonBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WaferBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource WaferTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Border" Property="Background" Value="{StaticResource WaferButtonHoverBrush}" />
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="#9BB9C3" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PART_Border" Property="Background" Value="{StaticResource WaferButtonPressedBrush}" />
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{StaticResource WaferAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{StaticResource WaferAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource WaferButtonBaseStyle}" />

    <Style x:Key="WaferToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource WaferButtonBaseStyle}">
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="3,0" />
        <Setter Property="Padding" Value="10,0" />
    </Style>

    <Style x:Key="WaferToolbarTextButtonStyle" TargetType="Button" BasedOn="{StaticResource WaferButtonBaseStyle}">
        <Setter Property="MinWidth" Value="76" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="WaferToolbarModeRadioStyle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
        <Setter Property="Height" Value="34" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource WaferTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="WaferDenseButtonStyle" TargetType="Button" BasedOn="{StaticResource WaferButtonBaseStyle}">
        <Setter Property="MinWidth" Value="68" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="3" />
        <Setter Property="Padding" Value="10,0" />
    </Style>

    <Style x:Key="WaferPropertyCategoryStyle"
           TargetType="Expander"
           BasedOn="{StaticResource Expander.Small}">
        <Setter Property="IsExpanded" Value="True" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{StaticResource WaferPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WaferBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource WaferTextBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock VerticalAlignment="Center"
                               FontFamily="Microsoft YaHei UI"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource WaferTextBrush}"
                               Text="{Binding}"
                               TextTrimming="CharacterEllipsis" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Border x:Name="PART_Root"
                            HorizontalAlignment="Stretch"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ToggleButton x:Name="PART_Header"
                                          Grid.Row="0"
                                          MinHeight="44"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Center"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Content="{TemplateBinding Header}"
                                          ContentStringFormat="{TemplateBinding HeaderStringFormat}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}"
                                          Focusable="False"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="PART_HeaderBorder"
                                                HorizontalAlignment="Stretch"
                                                Background="#F8FBFD"
                                                BorderBrush="{StaticResource WaferBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                CornerRadius="6,6,0,0">
                                            <Grid Margin="12,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="4"
                                                        Height="18"
                                                        VerticalAlignment="Center"
                                                        Background="{StaticResource WaferAccentBrush}"
                                                        CornerRadius="2" />
                                                <ContentPresenter Grid.Column="1"
                                                                  Margin="10,0,8,0"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  Content="{TemplateBinding Content}"
                                                                  ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                                  RecognizesAccessKey="True" />
                                                <Border Grid.Column="2"
                                                        Width="24"
                                                        Height="24"
                                                        VerticalAlignment="Center"
                                                        Background="#ECF4F8"
                                                        CornerRadius="12">
                                                    <Path x:Name="PART_Arrow"
                                                          Width="9"
                                                          Height="6"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Data="M 0 0 L 4.5 6 L 9 0 Z"
                                                          Fill="{StaticResource WaferAccentBrush}"
                                                          RenderTransformOrigin="0.5,0.5"
                                                          Stretch="Fill">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="0" />
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="PART_HeaderBorder" Property="Background" Value="#F1F7FA" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="PART_HeaderBorder" Property="Background" Value="#E7F1F5" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="PART_HeaderBorder" Property="BorderThickness" Value="0" />
                                                <Setter TargetName="PART_HeaderBorder" Property="CornerRadius" Value="6" />
                                                <Setter TargetName="PART_Arrow" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="-90" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.55" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="PART_ExpandSite"
                                              Grid.Row="1"
                                              Content="{TemplateBinding Content}"
                                              ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                              Focusable="False" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="PART_ExpandSite" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Root" Property="BorderBrush" Value="#C6D5E4" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WaferWorkflowButtonStyle" TargetType="Button" BasedOn="{StaticResource WaferButtonBaseStyle}">
        <Setter Property="Height" Value="38" />
        <Setter Property="Margin" Value="4" />
    </Style>

    <Style x:Key="WaferWorkflowPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource WaferWorkflowButtonStyle}">
        <Setter Property="Background" Value="{StaticResource WaferAccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WaferAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="WaferWorkflowWarningButtonStyle" TargetType="Button" BasedOn="{StaticResource WaferWorkflowButtonStyle}">
        <Setter Property="Background" Value="{StaticResource WaferWarningBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WaferWarningBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="WaferWorkflowDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource WaferWorkflowButtonStyle}">
        <Setter Property="Background" Value="{StaticResource WaferDangerBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WaferDangerBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="WaferPropertyPanelStyle" TargetType="Grid">
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="WaferPropertyRowStyle" TargetType="Grid">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <Style x:Key="WaferPropertyLabelStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="10,0,12,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource WaferTextBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="WaferPropertyEditorComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="0,2,6,2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="WaferPropertyButtonStyle" TargetType="Button" BasedOn="{StaticResource WaferButtonBaseStyle}">
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="0,4,6,4" />
    </Style>

    <Style x:Key="WaferNumericStyle"
           TargetType="hc:NumericUpDown"
           BasedOn="{StaticResource {x:Type hc:NumericUpDown}}">
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="0,2,6,2" />
        <Setter Property="Minimum" Value="-100000" />
        <Setter Property="Maximum" Value="100000" />
        <Setter Property="DecimalPlaces" Value="3" />
        <Setter Property="Increment" Value="0.1" />
    </Style>
</ResourceDictionary>
