<UserControl x:Class="WaferMap.Wpf.Views.WaferHeadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:model="clr-namespace:WaferMap.Wpf.Model"
             Height="60"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WaferMap.Wpf;component/Themes/WaferMapHandyTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="WaferSyncToolbarButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource WaferToolbarTextButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSyncEnabled}" Value="True">
                        <Setter Property="Background" Value="{StaticResource WaferAccentBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource WaferAccentBrush}" />
                        <Setter Property="Foreground" Value="White" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Padding="12,10"
            Background="{StaticResource WaferPanelBrush}"
            BorderBrush="{StaticResource WaferBorderBrush}"
            BorderThickness="0,0,0,1">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Command="{Binding LoadMapCommand}"
                        Style="{StaticResource WaferToolbarTextButtonStyle}"
                        ToolTip="打开晶圆图">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE8E5;" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="打开" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SaveMapCommand}"
                        Style="{StaticResource WaferToolbarTextButtonStyle}"
                        ToolTip="保存晶圆图">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE74E;" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="保存" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Separator DockPanel.Dock="Left"
                       Width="1"
                       Margin="4,4,8,4"
                       Background="{StaticResource WaferBorderBrush}" />

            <StackPanel DockPanel.Dock="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <RadioButton Command="{Binding SetModeCommand}"
                             CommandParameter="{x:Static model:WaferMapOperationalEnum.Move}"
                             Content="移动"
                             GroupName="WaferMode"
                             IsChecked="{Binding IsMoveMode, Mode=OneWay}"
                             Style="{StaticResource WaferToolbarModeRadioStyle}" />
                <RadioButton Command="{Binding SetModeCommand}"
                             CommandParameter="{x:Static model:WaferMapOperationalEnum.SelectorDeselect}"
                             Content="待测/不测"
                             GroupName="WaferMode"
                             IsChecked="{Binding IsSelectMode, Mode=OneWay}"
                             Style="{StaticResource WaferToolbarModeRadioStyle}" />
                <RadioButton Command="{Binding SetModeCommand}"
                             CommandParameter="{x:Static model:WaferMapOperationalEnum.AddorRemove}"
                             Content="添加/删除"
                             GroupName="WaferMode"
                             IsChecked="{Binding IsAddMode, Mode=OneWay}"
                             Style="{StaticResource WaferToolbarModeRadioStyle}" />
            </StackPanel>

            <Separator DockPanel.Dock="Left"
                       Width="1"
                       Margin="4,4,8,4"
                       Background="{StaticResource WaferBorderBrush}" />

            <StackPanel DockPanel.Dock="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Command="{Binding SetHomeCommand}"
                        Style="{StaticResource WaferToolbarTextButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE80F;" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="设原点" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ToggleSyncHomeCommand}"
                        Style="{StaticResource WaferSyncToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE895;" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="同步" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SelectAllCommand}"
                        Style="{StaticResource WaferToolbarTextButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE762;" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="全选" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SelectWithoutEdgeCommand}"
                        Style="{StaticResource WaferToolbarTextButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE8A1;" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="内部" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearSelectionCommand}"
                        Style="{StaticResource WaferToolbarTextButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE74D;" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="清空" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Border Width="250"
                        Margin="8,0"
                        Padding="8,4"
                        Background="#F3F6FA"
                        BorderBrush="{StaticResource WaferBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock Foreground="{StaticResource WaferMutedTextBrush}"
                               Text="{Binding SelectedIndexText}"
                               TextTrimming="CharacterEllipsis" />
                </Border>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
