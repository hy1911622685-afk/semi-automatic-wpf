<UserControl x:Class="WaferMap.Wpf.Views.BinsConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WaferMap.Wpf;component/Themes/WaferMapHandyTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="5">
        <Border Style="{StaticResource WaferCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Style="{StaticResource WaferSectionTitleStyle}"
                           Text="分档" />

                <Grid Grid.Row="1"
                      Margin="12,4,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" MinWidth="90" />
                        <ColumnDefinition Width="1.4*" MinWidth="110" />
                        <ColumnDefinition Width="*" MinWidth="90" />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="{StaticResource WaferMutedTextBrush}"
                               Text="代码" />
                    <TextBlock Grid.Column="1"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource WaferMutedTextBrush}"
                               Text="命令" />
                    <TextBlock Grid.Column="2"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource WaferMutedTextBrush}"
                               Text="描述" />
                    <TextBlock Grid.Column="3"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource WaferMutedTextBrush}"
                               Text="颜色" />
                </Grid>

                <ListBox Grid.Row="2"
                         MinHeight="120"
                         Padding="4"
                         Background="#F8FAFD"
                         BorderBrush="{StaticResource WaferBorderBrush}"
                         ItemsSource="{Binding BinDefinitions}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectedItem="{Binding SelectedBinDefinition}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8"
                                    Background="White"
                                    BorderBrush="{StaticResource WaferBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="*" MinWidth="90" />
                                        <ColumnDefinition Width="1.4*" MinWidth="110" />
                                        <ColumnDefinition Width="*" MinWidth="90" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="30"
                                            Height="30"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#F3F6FA"
                                            BorderBrush="{StaticResource WaferBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="15">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource WaferTextBrush}"
                                                   Text="{Binding DisplayIndex}" />
                                    </Border>
                                    <TextBox Grid.Column="1"
                                             Margin="4,0"
                                             IsReadOnly="{Binding IsSystemDefault}"
                                             Text="{Binding BinCommand, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Column="2"
                                             Margin="4,0"
                                             IsReadOnly="{Binding IsSystemDefault}"
                                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                                    <Border Grid.Column="3"
                                            Width="58"
                                            Height="24"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{Binding ColorBrush}"
                                            BorderBrush="{StaticResource WaferBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="3"
                        Margin="0,10,0,0"
                        Padding="10"
                        Background="#F8FAFD"
                        BorderBrush="{StaticResource WaferBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedBinDefinition}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal">
                            <Border Width="22"
                                    Height="22"
                                    Background="{Binding SelectedBinDefinition.ColorBrush}"
                                    BorderBrush="{StaticResource WaferBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource WaferTextBrush}"
                                       Text="选中分档颜色" />
                        </StackPanel>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <hc:ColorPicker Grid.Column="0"
                                            Height="34"
                                            HorizontalAlignment="Stretch"
                                            SelectedBrush="{Binding SelectedBinDefinition.ColorBrush, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Grid.Column="2"
                                     MinWidth="112"
                                     Height="34"
                                     Text="{Binding SelectedBinDefinition.ColorHex, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <UniformGrid Grid.Row="4"
                                     Columns="3">
                            <StackPanel MinWidth="92"
                                        Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource WaferFieldLabelStyle}" Text="R" />
                                <hc:NumericUpDown DecimalPlaces="0"
                                                  Height="32"
                                                  Increment="1"
                                                  Minimum="0"
                                                  Maximum="255"
                                                  Value="{Binding SelectedBinDefinition.ColorR, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel MinWidth="92"
                                        Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource WaferFieldLabelStyle}" Text="G" />
                                <hc:NumericUpDown DecimalPlaces="0"
                                                  Height="32"
                                                  Increment="1"
                                                  Minimum="0"
                                                  Maximum="255"
                                                  Value="{Binding SelectedBinDefinition.ColorG, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel MinWidth="92">
                                <TextBlock Style="{StaticResource WaferFieldLabelStyle}" Text="B" />
                                <hc:NumericUpDown DecimalPlaces="0"
                                                  Height="32"
                                                  Increment="1"
                                                  Minimum="0"
                                                  Maximum="255"
                                                  Value="{Binding SelectedBinDefinition.ColorB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="4"
                             Margin="0,12,0,0"
                             VerticalAlignment="Bottom"
                             Columns="3">
                    <Button Command="{Binding AddBinCommand}"
                            Content="添加"
                            Style="{StaticResource WaferDenseButtonStyle}" />
                    <Button Command="{Binding DeleteBinCommand}"
                            Content="删除"
                            Style="{StaticResource WaferDenseButtonStyle}" />
                    <Button Command="{Binding SaveBinsCommand}"
                            Content="保存"
                            Style="{StaticResource WaferDenseButtonStyle}" />
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
